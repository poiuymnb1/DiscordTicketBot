# ============================================
# DiscordTicketBot — Configuration
# ============================================

# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=

# SQLite Database Path (optional, default: data/tickets.db)
# For Docker, the default path is /app/data/tickets.db
DATABASE_PATH=data/tickets.db

# Command prefix (for text commands)
COMMAND_PREFIX=!

# Optional: Proxy URL for bypassing Discord blocks
# Format: socks5://user:pass@host:port or http://host:port
# PROXY_URL=