# ============================================
# DiscordTicketBot — Configuration
# ============================================

# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=

# PostgreSQL Database
# Format: postgresql://user:password@host:port/dbname
# For Docker: postgresql://postgres:DB_PASSWORD@db:5432/DiscordTicketBot
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/discordticketbot

# Optional: Database password (used in Docker Compose)
DB_PASSWORD=changeme

# Command prefix (for text commands)
COMMAND_PREFIX=!